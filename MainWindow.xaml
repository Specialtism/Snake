<Window x:Class="Snake.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Snake"
        mc:Ignorable="d"
        Title="Snake" Height="500" Width="800"
        MinWidth="300" MinHeight="300"
        Background="{StaticResource BackgroundColor}"
        Foreground="{StaticResource TextColor}"
        FontFamily="{StaticResource MainFont}"
        WindowStartupLocation="CenterScreen"
        Icon="Assets/icon.ico"
        PreviewKeyDown="Window_PreviewKeyDown"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <Storyboard x:Key="SpeedBoostAnimation">
            <DoubleAnimation Storyboard.TargetName="SpeedBoostOverlay" 
                         Storyboard.TargetProperty="Opacity" 
                         From="1.0" To="0.0" 
                         Duration="0:0:1" />
        </Storyboard>
    </Window.Resources>
    <Viewbox>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10">
                <TextBlock x:Name="ScoreText"
               Text="SCORE 0"
               FontSize="22"
               Margin="0,0,30,0"/>

                <TextBlock x:Name="SpeedText"
               Text="DELAY 100"
               FontSize="22"/>
            </StackPanel>

            <Border x:Name="GridBorder"
                Grid.Row="1"
                BorderBrush="{StaticResource GridLineColor}"
                BorderThickness="1.5"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                RenderOptions.EdgeMode="Aliased"
                Margin="20,0,20,20" >
                <UniformGrid x:Name="GameGrid"
                         Width="800"
                         Height="800"
                         Background="{StaticResource GridBackgroundColor}"
                         SnapsToDevicePixels="True"
                         RenderOptions.BitmapScalingMode="HighQuality">
                </UniformGrid>

            </Border>

            <Border x:Name="Overlay"
                    Grid.Row="1"
                    Background="{StaticResource OverLayColor}"
                    Width="{Binding Path=ActualWidth, ElementName=GridBorder}"
                    Height="{Binding Path=ActualHeight, ElementName=GridBorder}"
                    Margin="{Binding Path=Margin, ElementName=GridBorder}"
                    RenderOptions.EdgeMode="Aliased">
                <TextBlock x:Name="OverlayText"
                          Text="PRESS ANY KEY TO START"
                          FontSize="26"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          TextWrapping="Wrap"/>
            </Border>
            <Border x:Name="MainMenuOverlay"
                Grid.Row="1"
                Background="{StaticResource OverLayColor}"
                Width="{Binding Path=ActualWidth, ElementName=GridBorder}"
                Height="{Binding Path=ActualHeight, ElementName=GridBorder}"
                Margin="{Binding Path=Margin, ElementName=GridBorder}"
                RenderOptions.EdgeMode="Aliased">

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="SNAKE" 
                           FontSize="48" 
                           FontWeight="Bold" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,30" />

                    <Button x:Name="BtnClassic" 
                        Content="CLASSIC MODE" 
                        FontSize="20" 
                        Padding="20,10" 
                        Margin="0,10" 
                        Click="BtnClassic_Click"/>
					<CheckBox x:Name="ChkHardMode"
                      Content="ENABLE HARD MODE (Speed Boost Items)"
                      FontSize="16"
                      Foreground="{StaticResource TextColor}"
                      HorizontalAlignment="Center"
                      Margin="0,0,0,10"/>

                    <Button x:Name="BtnLargeGrid" 
                        Content="LARGE GRID MODE" 
                        FontSize="20" 
                        Padding="20,10" 
                        Margin="0,10" 
                        Click="BtnLargeGrid_Click"/>


					<TextBlock x:Name="LeaderboardText"
				   FontSize="18"
				   Margin="0,20,0,0"
				   HorizontalAlignment="Center"
				   TextAlignment="Center"/>

				</StackPanel>
            </Border>

            <Border x:Name="SpeedBoostOverlay" 
                BorderBrush="Red" 
                BorderThickness="5" 
                Opacity="0" 
                IsHitTestVisible="False" />


        </Grid>
    </Viewbox>
</Window>
